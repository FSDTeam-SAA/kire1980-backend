      "name": "Create Booking",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{authToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"serviceId\": \"{{serviceId}}\",\n  \"businessId\": \"{{businessId}}\",\n  \"dateAndTime\": \"2026-03-15T10:00:00.000Z\",\n  \"selectedProvider\": \"{{staffId}}\",\n  \"notes\": \"Please use organic hair products\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/bookings",
          "host": ["{{baseUrl}}"],
          "path": ["bookings"]
        },
        "description": "Create a new booking. Requires authentication. Validates service, business, staff member assignment, and time slot availability."
